# =====================================================
# SIGTS Frontend Environment Configuration
# =====================================================
# Copy this file to frontend/.env for local frontend runs.
# On Vercel, add these under Project Settings > Environment Variables.
#
# The frontend only receives public runtime configuration. Never put database
# passwords, JWT secrets, SMTP credentials, or Twilio secrets here.

# Local/static build mode.
NODE_ENV=development

# Frontend dev server port.
FRONTEND_PORT=3000

# Backend API URL.
# Local frontend dev:
API_URL=http://localhost:8001/api
API_PORT=8001
#
# Vercel frontend + Vercel API in the same project:
# leave API_URL blank so the browser uses same-origin /api.
#
# Vercel frontend + Render backend:
API_URL=https://sigts-repo.onrender.com/api

MAP_TILES_URL=/tiles
PARK_NAME=Bwindi Impenetrable National Park
DEFAULT_LANGUAGE=en

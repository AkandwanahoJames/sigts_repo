# Frontend runtime (used by scripts/generateRuntimeConfig.js)
# Copy to frontend/.env and run: node scripts/generateRuntimeConfig.js

# Leave empty to auto-detect from backend/.env PORT (recommended)
# API_URL=http://localhost:8000/api
API_PORT=8000

NODE_ENV=development
MAP_TILES_URL=/tiles
PARK_NAME=Bwindi Impenetrable National Park
DEFAULT_LANGUAGE=en

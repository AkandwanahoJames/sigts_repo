# =====================================================
# SIGTS Backend Environment Configuration
# =====================================================
# Copy this file to backend/.env and fill in actual values.
# Backend startup now also supports repo-root .env, but backend/.env is preferred.

# =====================================================
# NODE ENVIRONMENT
# =====================================================
NODE_ENV=development
PORT=8000
HOST=0.0.0.0

# =====================================================
# SECURITY - CRITICAL: MUST SET IN PRODUCTION
# =====================================================
# Generate a strong JWT secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-generate-with-crypto
JWT_ACCESS_TTL=24h
# 0 = disable server-side idle session enforcement (JWT access TTL still applies).
SESSION_IDLE_TIMEOUT_MINUTES=30
BCRYPT_ROUNDS=12

# =====================================================
# DATABASE - PostgreSQL (local or Supabase)
# =====================================================
# Production (Supabase): paste URI from Project Settings → Database → URI
# DATABASE_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
#
# Local discrete settings:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sigts_bwindi
DB_USER=postgres
# Use your real local password. Example only:
DB_PASSWORD=your-postgres-password
# DB_SSL=true
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

# =====================================================
# REDIS - Session storage & caching
# =====================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =====================================================
# CLIENT URLs - CORS Configuration
# =====================================================
CLIENT_URL=http://localhost:3000,http://localhost:3001
PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# EMAIL SERVICE (Optional - for notifications)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@bwindi.com
# SMTP_PASS is also accepted (alias for SMTP_PASSWORD)
SMTP_PASS=

# =====================================================
# SMS (Twilio) — registration welcome + MFA codes
# =====================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# =====================================================
# FEATURE FLAGS
# =====================================================
ENABLE_WEBSOCKET=true
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_OFFLINE_SYNC=true

# =====================================================
# API RATE LIMITING
# =====================================================
GENERAL_RATE_LIMIT_WINDOW_MS=900000
# 3000 per 15 min supports IT dashboard polling; presence/refresh are excluded from the cap
GENERAL_RATE_LIMIT_MAX=3000
# Set true to disable API rate limiting (development disables automatically when NODE_ENV is not production)
DISABLE_API_RATE_LIMIT=false
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# =====================================================
# UPLOAD CONFIGURATION
# =====================================================
MAX_UPLOAD_SIZE=10mb
UPLOAD_PATH=./uploads
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
ALLOWED_AUDIO_TYPES=mp3,wav,m4a

# =====================================================
# AI RECOMMENDATIONS ENGINE
# =====================================================
AI_MODEL=recommendation-engine-v1
AI_CONFIDENCE_THRESHOLD=0.7

# =====================================================
# TOUR HELP CHAT (LLM — OpenAI-compatible API recommended for full answers)
# When unset or disabled, /ai/chat uses rule_kb_v1 (offline-safe curated interpreter).
# Grounding pulls live SIGTS data: parks, FAQs, safety, park guide, animals, themes,
# cultural narratives, locations, tour content, routes, sightings + client catalogue snapshot.
# =====================================================
SIGTS_CHAT_OPENAI_API_KEY=
# SIGTS_CHAT_OPENAI_BASE=https://api.openai.com
# SIGTS_CHAT_MODEL=gpt-4o
# SIGTS_CHAT_TEMPERATURE=0.52
# SIGTS_CHAT_MAX_TOKENS=1024
# SIGTS_CHAT_TIMEOUT_MS=22000
# SIGTS_CHAT_DISABLE_LLM=false

# =====================================================
# GEOFENCING
# =====================================================
GEOFENCE_RADIUS_METERS=100
GEOFENCE_CHECK_INTERVAL_MS=5000

# =====================================================
# SUPPORTED LANGUAGES
# =====================================================
SUPPORTED_LANGUAGES=en,fr,local
DEFAULT_LANGUAGE=en

# =====================================================
# PRODUCTION DEPLOYMENT (§3.7 future work)
# =====================================================
# NODE_ENV=production
# CLIENT_URL=https://your-frontend.example.com
# ENABLE_AUTH_RATE_LIMIT=true
# GENERAL_RATE_LIMIT_MAX=200
# Run: npm run migrate --workspace=backend  (includes last_location_time for presence)

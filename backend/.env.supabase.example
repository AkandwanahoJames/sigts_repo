# Copy to backend/.env.supabase (gitignored).
#
# Supabase "Copy" gives URLs with [YOUR-PASSWORD] — that is intentional.
# After reset, Supabase shows the password ONCE. Paste it below.

SUPABASE_PROJECT_REF=hjculkldwjrsifvnaugy
SUPABASE_POOLER_REGION=eu-west-1
DATABASE_PASSWORD=YOUR_PASSWORD_HERE

# Optional: set full URIs yourself instead of DATABASE_PASSWORD + ref/region:
# DATABASE_URL_POOLER=postgresql://postgres.hjculkldwjrsifvnaugy:...@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# DATABASE_URL_DIRECT=postgresql://postgres:...@db.hjculkldwjrsifvnaugy.supabase.co:5432/postgres

{
  "version": 2,
  "installCommand": "cd .. && npm install",
  "buildCommand": "cd .. && npm run build --workspace=sigts-frontend",
  "outputDirectory": "../frontend/public",
  "routes": [
    {
      "src": "/(.*\\.(?:html|js|css|json|webmanifest|svg|png|jpg|jpeg|webp|ico|woff|woff2))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

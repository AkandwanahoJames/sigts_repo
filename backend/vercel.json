{
  "version": 2,
  "installCommand": "npm install --prefix ..",
  "buildCommand": "npm run build --prefix ../frontend",
  "outputDirectory": "../frontend/public",
  "framework": null,
  "routes": [
    {
      "src": "/(.*\\.(?:html|js|css|json|webmanifest|svg|png|jpg|jpeg|webp|ico|woff|woff2))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
